{
    "name": "cybex/laravel-protector",
    "description": "Protect Databases by generating Backups and Import those on non-productive Environments.",
    "keywords": [
        "cybex",
        "laravel",
        "database",
        "backup",
        "sync",
        "encryption",
        "protector"
    ],
    "homepage": "https://github.com/cybex-gmbh/laravel-protector",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Marco Szulik",
            "email": "webdevelopment@cybex-online.com",
            "role": "Developer"
        },
        {
            "name": "Oliver Matla",
            "email": "info@lupinitylabs.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-sodium": "*",
        "guzzlehttp/guzzle": "^7.4",
        "laravel/framework": "^12.1.1|^13.0",
        "laravel/sanctum": "^4.0"
    },
    "require-dev": {
        "laravel/pint": "^1.17",
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Cybex\\Protector\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cybex\\Protector\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit -c phpunit.xml.dist",
        "test-postgres": "vendor/bin/phpunit -c phpunit-postgres.xml.dist",
        "test-mysql": "vendor/bin/phpunit -c phpunit-mysql.xml.dist"
    },
    "config": {
        "sort-packages": true,
        "audit": {
            "block-insecure": false
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cybex\\Protector\\ProtectorServiceProvider"
            ],
            "aliases": {
                "Protector": "Cybex\\Protector\\Facades\\ProtectorFacade",
                "ProtectorConfigurator": "Cybex\\Protector\\Facades\\ProtectorConfiguratorFacade"
            }
        }
    }
}
